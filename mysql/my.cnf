[mysqld]
server-id                  = 1
log_bin                    = mysql-bin
binlog_format              = ROW
binlog_row_image           = FULL
expire_logs_days           = 10
gtid_mode                  = ON
enforce_gtid_consistency   = ON

# Performance
innodb_buffer_pool_size    = 512M
max_connections            = 200
connect_timeout            = 60

# Character set
character-set-server       = utf8mb4
collation-server           = utf8mb4_unicode_ci
