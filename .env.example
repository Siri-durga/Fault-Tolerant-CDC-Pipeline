# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=ecommerce
MYSQL_USER=debezium
MYSQL_PASSWORD=dbzpassword
MYSQL_PORT=3306

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1

# Kafka Connect / Debezium Configuration
CONNECT_BOOTSTRAP_SERVERS=kafka:9092
CONNECT_REST_PORT=8083
CONNECT_GROUP_ID=cdc-connect-group
CONNECT_CONFIG_STORAGE_TOPIC=connect-configs
CONNECT_OFFSET_STORAGE_TOPIC=connect-offsets
CONNECT_STATUS_STORAGE_TOPIC=connect-status
CONNECT_KEY_CONVERTER=org.apache.kafka.connect.json.JsonConverter
CONNECT_VALUE_CONVERTER=org.apache.kafka.connect.json.JsonConverter

# Debezium MySQL Connector Settings
DEBEZIUM_CONNECTOR_NAME=mysql-cdc-connector
DEBEZIUM_DB_HOSTNAME=mysql
DEBEZIUM_DB_PORT=3306
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=dbzpassword
DEBEZIUM_DB_SERVER_NAME=ecommerce_server
DEBEZIUM_DB_NAME=ecommerce
DEBEZIUM_DB_TABLES=ecommerce.customers,ecommerce.products,ecommerce.orders

# Processor Service Configuration
PROCESSOR_KAFKA_TOPIC_PREFIX=ecommerce_server.ecommerce
PROCESSOR_DATA_LAKE_PATH=/data_lake
PROCESSOR_STATE_PATH=/state
PROCESSOR_LOG_LEVEL=INFO

# Schema Store
SCHEMA_STORE_PATH=/state/schemas.db

# Lineage Report
LINEAGE_REPORT_PATH=/output/lineage_report.json
